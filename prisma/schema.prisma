generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  ACCOUNTANT
  ANALYST
  CLIENT
}

enum ComplianceStatus {
  ON_TRACK
  AT_RISK
  OVERDUE
}

enum AssignmentStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ReminderChannel {
  EMAIL
  WHATSAPP
  IN_APP
}

model Firm {
  id          String       @id @default(cuid())
  name        String
  users       User[]
  companies   Company[]
  notes       Note[]
  assignments Assignment[]
  reminders   Reminder[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model User {
  id          String       @id @default(cuid())
  firmId      String
  fullName    String
  email       String       @unique
  role        UserRole
  isActive    Boolean      @default(true)
  firm        Firm         @relation(fields: [firmId], references: [id], onDelete: Cascade)
  assignments Assignment[] @relation("AssignmentAssignee")
  notes       Note[]       @relation("NoteAuthor")
  reminders   Reminder[]   @relation("ReminderOwner")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([id, firmId])
  @@index([firmId, role])
}

model Company {
  id             String             @id @default(cuid())
  firmId         String
  legalName      String
  taxId          String
  isVatPayer     Boolean            @default(true)
  billingEmail   String
  collectionLead Int                @default(0)
  firm           Firm               @relation(fields: [firmId], references: [id], onDelete: Cascade)
  metrics        ComplianceMetric[]
  notes          Note[]
  assignments    Assignment[]
  reminders      Reminder[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([id, firmId])
  @@unique([firmId, taxId])
  @@index([firmId])
}

model ComplianceMetric {
  id                String           @id @default(cuid())
  companyId         String
  periodLabel       String
  invoicesStatus    ComplianceStatus @default(ON_TRACK)
  collectionsStatus ComplianceStatus @default(ON_TRACK)
  eFacturaStatus    ComplianceStatus @default(ON_TRACK)
  safTStatus        ComplianceStatus @default(ON_TRACK)
  taxDeadlineStatus ComplianceStatus @default(ON_TRACK)
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())

  @@unique([companyId, periodLabel])
}

model Note {
  id        String   @id @default(cuid())
  firmId    String
  companyId String
  authorId  String
  title     String
  body      String
  isPinned  Boolean  @default(false)
  firm      Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId, firmId], references: [id, firmId], onDelete: Cascade)
  author    User     @relation("NoteAuthor", fields: [authorId, firmId], references: [id, firmId], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([firmId, companyId, createdAt])
}

model Assignment {
  id          String           @id @default(cuid())
  firmId      String
  companyId   String
  assigneeId  String
  title       String
  description String
  dueDate     DateTime
  status      AssignmentStatus @default(TODO)
  firm        Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  company     Company          @relation(fields: [companyId, firmId], references: [id, firmId], onDelete: Cascade)
  assignee    User             @relation("AssignmentAssignee", fields: [assigneeId, firmId], references: [id, firmId], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@index([firmId, dueDate])
}

model Reminder {
  id          String          @id @default(cuid())
  firmId      String
  companyId   String
  ownerId     String
  title       String
  message     String
  scheduledAt DateTime
  channel     ReminderChannel @default(IN_APP)
  sentAt      DateTime?
  firm        Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  company     Company         @relation(fields: [companyId, firmId], references: [id, firmId], onDelete: Cascade)
  owner       User            @relation("ReminderOwner", fields: [ownerId, firmId], references: [id, firmId], onDelete: Cascade)
  createdAt   DateTime        @default(now())

  @@index([firmId, scheduledAt])
}
