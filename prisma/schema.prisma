generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  ACCOUNTANT
  AUDITOR
  CLIENT
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  LEFT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REVERSED
}

enum CollectionCaseStatus {
  OPEN
  IN_NEGOTIATION
  ESCALATED
  RESOLVED
  WRITTEN_OFF
}

enum EFacturaStatus {
  QUEUED
  SENT
  ACCEPTED
  REJECTED
  ERROR
}

enum SaftProjectStatus {
  PLANNED
  COLLECTING_DATA
  VALIDATING
  SUBMITTED
  BLOCKED
}

enum TaxDeadlineStatus {
  UPCOMING
  SUBMITTED
  MISSED
}

enum AssignmentStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum ReminderChannel {
  EMAIL
  WHATSAPP
  IN_APP
}

enum ReminderStatus {
  SCHEDULED
  SENT
  FAILED
  CANCELED
}

enum AuditActorType {
  USER
  SYSTEM
  API
}

model User {
  id            String       @id @default(cuid())
  fullName      String
  email         String       @unique
  isActive      Boolean      @default(true)
  memberships   Membership[]
  notesAuthored Note[]       @relation("NoteAuthor")
  assignments   Assignment[] @relation("AssignmentAssignee")
  reminders     Reminder[]   @relation("ReminderOwner")
  auditLogs     AuditLog[]   @relation("AuditActor")
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([deletedAt])
}

model AccountingFirm {
  id                   String                @id @default(cuid())
  name                 String
  memberships          Membership[]
  clientCompanies      ClientCompany[]
  smartBillConnections SmartBillConnection[]
  invoices             Invoice[]
  payments             Payment[]
  collectionCases      CollectionCase[]
  eFacturaChecks       EFacturaCheck[]
  saftProjects         SaftProject[]
  taxDeadlines         TaxDeadline[]
  notes                Note[]
  assignments          Assignment[]
  reminders            Reminder[]
  auditLogs            AuditLog[]
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([deletedAt])
}

model Membership {
  id        String           @id @default(cuid())
  userId    String
  firmId    String
  role      MembershipRole
  status    MembershipStatus @default(ACTIVE)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  firm      AccountingFirm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, firmId])
  @@index([firmId, role, status])
  @@index([userId, status])
  @@index([deletedAt])
}

model ClientCompany {
  id                  String               @id @default(cuid())
  firmId              String
  legalName           String
  tradeName           String?
  taxId               String
  registrationNumber  String?
  billingEmail        String?
  isVatPayer          Boolean              @default(true)
  riskScore           Int                  @default(0)
  firm                AccountingFirm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  smartBillConnection SmartBillConnection?
  invoices            Invoice[]
  payments            Payment[]
  collectionCases     CollectionCase[]
  eFacturaChecks      EFacturaCheck[]
  saftProjects        SaftProject[]
  taxDeadlines        TaxDeadline[]
  notes               Note[]
  assignments         Assignment[]
  reminders           Reminder[]
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([firmId, taxId])
  @@index([firmId, legalName])
  @@index([firmId, deletedAt])
}

model SmartBillConnection {
  id              String         @id @default(cuid())
  firmId          String
  clientCompanyId String         @unique
  companyVatCode  String
  username        String
  tokenLast4      String
  syncEnabled     Boolean        @default(true)
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  firm            AccountingFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([firmId, syncEnabled])
  @@index([firmId, deletedAt])
}

model Invoice {
  id              String           @id @default(cuid())
  firmId          String
  clientCompanyId String
  number          String
  issueDate       DateTime
  dueDate         DateTime
  currency        String           @default("RON")
  totalAmount     Decimal          @db.Decimal(14, 2)
  paidAmount      Decimal          @default(0) @db.Decimal(14, 2)
  status          InvoiceStatus    @default(DRAFT)
  externalId      String?
  firm            AccountingFirm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany    @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  payments        Payment[]
  collectionCases CollectionCase[]
  eFacturaChecks  EFacturaCheck[]
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([firmId, number])
  @@index([firmId, status, dueDate])
  @@index([clientCompanyId, issueDate])
  @@index([firmId, deletedAt])
}

model Payment {
  id              String         @id @default(cuid())
  firmId          String
  clientCompanyId String
  invoiceId       String?
  amount          Decimal        @db.Decimal(14, 2)
  currency        String         @default("RON")
  paidAt          DateTime
  method          String?
  status          PaymentStatus  @default(CONFIRMED)
  reference       String?
  firm            AccountingFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([firmId, paidAt])
  @@index([invoiceId])
  @@index([firmId, deletedAt])
}

model CollectionCase {
  id              String               @id @default(cuid())
  firmId          String
  clientCompanyId String
  invoiceId       String?
  status          CollectionCaseStatus @default(OPEN)
  priority        Int                  @default(3)
  openedAt        DateTime             @default(now())
  closedAt        DateTime?
  notesSummary    String?
  firm            AccountingFirm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany        @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  invoice         Invoice?             @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([firmId, status, priority])
  @@index([clientCompanyId, status])
  @@index([firmId, deletedAt])
}

model EFacturaCheck {
  id              String         @id @default(cuid())
  firmId          String
  clientCompanyId String
  invoiceId       String?
  status          EFacturaStatus @default(QUEUED)
  checkedAt       DateTime       @default(now())
  responseCode    String?
  responseMessage String?
  firm            AccountingFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([firmId, status, checkedAt])
  @@index([clientCompanyId, checkedAt])
}

model SaftProject {
  id              String            @id @default(cuid())
  firmId          String
  clientCompanyId String
  periodLabel     String
  status          SaftProjectStatus @default(PLANNED)
  dueDate         DateTime?
  submittedAt     DateTime?
  validationScore Int?
  firm            AccountingFirm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany     @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([clientCompanyId, periodLabel])
  @@index([firmId, status, dueDate])
  @@index([firmId, deletedAt])
}

model TaxDeadline {
  id              String            @id @default(cuid())
  firmId          String
  clientCompanyId String
  label           String
  taxType         String
  dueDate         DateTime
  status          TaxDeadlineStatus @default(UPCOMING)
  submittedAt     DateTime?
  firm            AccountingFirm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany     @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([firmId, dueDate, status])
  @@index([clientCompanyId, dueDate])
  @@index([firmId, deletedAt])
}

model Note {
  id              String         @id @default(cuid())
  firmId          String
  clientCompanyId String
  authorId        String
  title           String
  body            String
  isPinned        Boolean        @default(false)
  firm            AccountingFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  author          User           @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([firmId, clientCompanyId, createdAt])
  @@index([firmId, deletedAt])
}

model Assignment {
  id              String           @id @default(cuid())
  firmId          String
  clientCompanyId String
  assigneeId      String
  title           String
  description     String
  dueDate         DateTime
  status          AssignmentStatus @default(TODO)
  firm            AccountingFirm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany    @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  assignee        User             @relation("AssignmentAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([firmId, status, dueDate])
  @@index([assigneeId, status, dueDate])
  @@index([firmId, deletedAt])
}

model Reminder {
  id              String          @id @default(cuid())
  firmId          String
  clientCompanyId String
  ownerId         String
  title           String
  message         String
  scheduledAt     DateTime
  channel         ReminderChannel @default(IN_APP)
  status          ReminderStatus  @default(SCHEDULED)
  sentAt          DateTime?
  firm            AccountingFirm  @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany   @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  owner           User            @relation("ReminderOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([firmId, status, scheduledAt])
  @@index([ownerId, status, scheduledAt])
  @@index([firmId, deletedAt])
}

model AuditLog {
  id         String         @id @default(cuid())
  firmId     String
  actorId    String?
  actorType  AuditActorType @default(USER)
  action     String
  entityType String
  entityId   String
  meta       Json?
  ipAddress  String?
  userAgent  String?
  firm       AccountingFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  actor      User?          @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([firmId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}
